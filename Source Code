# Text Cleaning Function
def clean_text(text):
    text = text.lower()
    text = re.sub(r'\s+', ' ', text)  # Remove extra spaces
    text = re.sub(r'[^a-zA-Z0-9\s.,!?]', '', text)  # Remove special characters
    return text.strip()

df["text"] = df["text"].apply(clean_text)

# Augment Dataset (Mark More Offensive Comments)
