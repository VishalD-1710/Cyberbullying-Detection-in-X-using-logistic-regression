#  Get User ID
def get_user_id(username):
    """Fetch user ID from username."""
    user = client.get_user(username=username)
    return user.data.id if user.data else None

#  Get Latest Tweets (User's posts)
def get_latest_tweets(user_id, max_results=5):
    """Fetch latest tweets from a user."""
    tweets = client.get_users_tweets(user_id, max_results=max_results)
    return [tweet.id for tweet in tweets.data] if tweets.data else []

#  Get Replies to User's Tweets (Filter out replies from the user themselves)
def get_replies(username, tweet_ids, target_user_id):
    """
    Fetch replies to the user's tweets by searching for tweets directed to the username,
    then filtering to include only those replies whose conversation_id matches the tweet ids,
    and excluding any replies made by the target user.
    """
    query = f"to:{username} -is:retweet"
    tweets = client.search_recent_tweets(query=query, tweet_fields=["conversation_id", "author_id", "text"])
    replies = []
    if tweets.data:
        for tweet in tweets.data:
            # Check if the reply belongs to one of the user's posts
            if str(tweet.conversation_id) in [str(tid) for tid in tweet_ids]:
                # Exclude replies posted by the target user themselves
                if tweet.author_id != target_user_id:
                    replies.append({"id": tweet.id, "text": tweet.text, "author_id": tweet.author_id})
    return replies

#  Detect Offensive Comments Using Logistic Regression
def detect_abuse(text):
    """Check if a reply contains offensive language using the trained ML model."""
    text = clean_text(text)
    text_vector = vectorizer.transform([text])
    prediction = lr.predict(text_vector)[0]
    return prediction == 1  # Returns True if offensive

